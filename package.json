{
  "name": "auris",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --import tsx server.ts",
    "build": "next build",
    "rebuild": "next build && pm2 restart auris",
    "start": "node --import tsx server.ts",
    "setup": "./setup.sh",
    "uninstall": "./uninstall.sh",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "waveforms:generate": "node --env-file=/etc/default/auris scripts/generate-waveforms.mjs",
    "waveforms:regenerate": "node --env-file=/etc/default/auris scripts/generate-waveforms.mjs --force",
    "waveforms:clear": "node --env-file=/etc/default/auris scripts/generate-waveforms.mjs --clear",
    "stop": "ss -tlnp 'sport = :3000' | grep -oP 'pid=\\K[0-9]+' | xargs -r kill",
    "auth:set": "node scripts/set-auth.mjs",
    "transcriptions:generate": "node --env-file=/etc/default/auris scripts/generate-transcriptions.mjs",
    "transcriptions:regenerate": "node --env-file=/etc/default/auris scripts/generate-transcriptions.mjs --force",
    "transcriptions:clear": "node --env-file=/etc/default/auris scripts/generate-transcriptions.mjs --clear"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

trym ALL=(ALL) NOPASSWD: /usr/bin/systemctl start auris-stream, \
                             /usr/bin/systemctl stop auris-stream, \
                             /usr/bin/systemctl restart auris-stream, \
                             /usr/bin/systemctl is-active auris-stream, \
                             /usr/bin/systemctl start auris-record, \
                             /usr/bin/systemctl stop auris-record, \
                             /usr/bin/systemctl restart auris-record, \
                             /usr/bin/systemctl is-active auris-record, \
                             /usr/bin/systemctl daemon-reload, \
                             /usr/bin/amixer -c *, \
                             /usr/bin/arecord -l, \
                             /usr/bin/aplay -l, \
                             /usr/bin/tee /etc/default/auris

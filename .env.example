# Stream URL (usually doesn't need changing)
NEXT_PUBLIC_STREAM_URL=/stream/mic

# Recordings directory (default: /recordings)
#RECORDINGS_DIR=/recordings

# SQLite database path (default: ./data/auris.db)
#DATABASE_PATH=./data/auris.db

# Auth secret (required when authentication is enabled)
# Generate with: openssl rand -base64 32
#AUTH_SECRET=

# Trust reverse proxy headers (set to true behind Nginx)
#AUTH_TRUST_HOST=true
